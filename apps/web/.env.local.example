# ═══════════════════════════════════════════════════════════════════════════════
# CairnConnect Web — Local Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env.local and fill in values for your local dev setup.
#
# Variables are grouped by priority:
#   [REQUIRED]  — Needed to start the app at all
#   [FEATURE]   — Needed only for a specific feature; app runs without them
#   [OPTIONAL]  — Nice-to-have / scripts-only
# ═══════════════════════════════════════════════════════════════════════════════


# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ [REQUIRED] SUPABASE — Core backend. The app will not work without these.   │
# └─────────────────────────────────────────────────────────────────────────────┘
# Get these from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Service role key — needed for admin operations (image uploads, etc.)
# WARNING: Never expose this in client-side code.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Database password — only needed for direct DB access / migrations
# SUPABASE_DB_PASSWORD=


# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ [FEATURE] MAPBOX — Interactive maps on the Explore page                    │
# └─────────────────────────────────────────────────────────────────────────────┘
# Get from: https://account.mapbox.com/access-tokens/
# NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...
# MAPBOX_SECRET_TOKEN=sk.eyJ1...


# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ [FEATURE] STRIPE — Payments, subscriptions, and Spotlight listings         │
# └─────────────────────────────────────────────────────────────────────────────┘
# Get from: https://dashboard.stripe.com/test/apikeys
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — create these in the Stripe dashboard or via the Stripe CLI
# STRIPE_SPOTLIGHT_FOUNDING_PRICE_ID=price_...
# STRIPE_SPOTLIGHT_STANDARD_PRICE_ID=price_...
# STRIPE_SPOTLIGHT_PREMIUM_PRICE_ID=price_...
# STRIPE_PRO_MONTHLY_PRICE_ID=price_...
# STRIPE_PRO_ANNUAL_PRICE_ID=price_...


# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ [FEATURE] SENDGRID — Transactional emails (welcome, notifications)         │
# └─────────────────────────────────────────────────────────────────────────────┘
# SENDGRID_API_KEY=SG.xxxx
# FROM_EMAIL=hello@cairnconnect.app


# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ [FEATURE] AI CHAT ASSISTANT — Cairn AI trail / trip advisor                │
# └─────────────────────────────────────────────────────────────────────────────┘
# Get from: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-...


# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ [FEATURE] DEVICE INTEGRATIONS — Strava & Garmin sync                       │
# └─────────────────────────────────────────────────────────────────────────────┘
# STRAVA_CLIENT_ID=
# STRAVA_CLIENT_SECRET=
# GARMIN_CONSUMER_KEY=
# GARMIN_CONSUMER_SECRET=
# TOKEN_ENCRYPTION_KEY=


# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ [OPTIONAL] DATA SEEDING — Scripts to import trail/business data            │
# └─────────────────────────────────────────────────────────────────────────────┘
# GOOGLE_PLACES_API_KEY=AIza...
# YELP_API_KEY=xxxx
# RECREATION_GOV_API_KEY=xxxx


# ┌─────────────────────────────────────────────────────────────────────────────┐
# │ [OPTIONAL] APP CONFIG                                                      │
# └─────────────────────────────────────────────────────────────────────────────┘
APP_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
